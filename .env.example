# Required: Kagi session token from your browser session
# Available from: https://kagi.com/settings/user_details
KAGI_SESSION_TOKEN=your_session_token_here

# Optional: Kagi Summarizer engine (default/agnes/muriel/cecil)
# KAGI_SUMMARIZER_ENGINE=default

# Container networking
MCP_PORT=8000
MCP_TRANSPORT=streamableHttp
MCP_STREAMABLE_HTTP_PATH=/mcp
MCP_SSE_PATH=/sse
MCP_MESSAGE_PATH=/message

# Optional log level for supergateway
MCP_LOG_LEVEL=info
